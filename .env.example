# LLM Provider: "claude" | "lm_studio"
LLM_PROVIDER=claude

# Anthropic Claude API
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# LM Studio (OpenAI-compatible local endpoint)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=

# MSSQL Connection
MSSQL_SERVER=your-server
MSSQL_PORT=1433
MSSQL_DATABASE=your_db
MSSQL_USER=your_user
MSSQL_PASSWORD=your_password
# Or direct connection string (overrides above):
# MSSQL_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=...;DATABASE=...;UID=...;PWD=...

# SP whitelist (comma-separated prefix match, empty = allow all)
SP_WHITELIST=

# Agent settings
AGENT_MAX_TURNS=10
MAX_CONVERSATION_HISTORY=20
