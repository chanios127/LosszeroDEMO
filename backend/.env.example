# LLM Provider: "claude" | "lm_studio"
LLM_PROVIDER=claude

# Anthropic Claude API
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Default max output tokens per Claude turn (per-request override via /api/query body).
CLAUDE_MAX_TOKENS=10000
# Extended-thinking budget when thinking_enabled=true (claude-haiku-4-5 / sonnet-4-5+ only).
CLAUDE_THINKING_BUDGET=4096

# LM Studio (OpenAI-compatible endpoint)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=
LM_STUDIO_API_KEY=lm-studio
# Default max output tokens per LM Studio turn.
LM_STUDIO_MAX_TOKENS=10000
# Per-phase httpx timeout in seconds. `read` covers reasoning models that take
# tens of seconds to emit the first token while inside <think>.
LM_STUDIO_TIMEOUT_CONNECT=10
LM_STUDIO_TIMEOUT_READ=600

# build_report input cap — long-text columns + row sampling before LLM call.
BUILD_REPORT_MAX_CELL_CHARS=200
BUILD_REPORT_MAX_ROWS=30

# SSE keep-alive comment line interval (seconds) — prevents proxy idle-close
# during long LLM reasoning silences. Pair with LM_STUDIO_TIMEOUT_READ.
SSE_HEARTBEAT_SEC=15

# MSSQL Connection (optional — set MOCK_DB=true to skip)
DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=your_db;UID=sa;PWD=yourpassword

# Mock mode: uses hardcoded sample data instead of real MSSQL
MOCK_DB=true

# SP whitelist (comma-separated, prefix match allowed)
SP_WHITELIST=

# Agent loop settings
AGENT_MAX_TURNS=10
