# LLM Provider: "claude" | "qwen"
LLM_PROVIDER=claude

# Anthropic Claude API
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Qwen3 via Ollama / vLLM (OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://localhost:11434
QWEN_MODEL=qwen3:32b

# MSSQL Connection (optional — set MOCK_DB=true to skip)
DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=your_db;UID=sa;PWD=yourpassword

# Mock mode: uses hardcoded sample data instead of real MSSQL
MOCK_DB=true

# SP whitelist (comma-separated, prefix match allowed)
SP_WHITELIST=

# Agent loop settings
AGENT_MAX_TURNS=10
